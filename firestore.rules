rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper to check if user is owner of resource (by ID)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check ownership via a field in the document
    function isDocumentOwner(data) {
      return isAuthenticated() && (
        data.authorId == request.auth.uid || 
        data.hostId == request.auth.uid || 
        data.userId == request.auth.uid ||
        data.deletedBy == request.auth.uid
      );
    }

    // Helper to check if user is admin
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isAuthenticated() && 
        (userDoc.data.role == 'admin' || userDoc.data.isAdmin == true || userDoc.data.isAdmin == 'true');
    }

    // ==========================================================
    // NOTICES
    // ==========================================================
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================================
    // PUBLIC COLLECTIONS (Global Feed)
    // ==========================================================

    // Posts: Public Read, Owner Write + Public Like/Report
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update: if isDocumentOwner(resource.data) || isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'scrappedBy', 'comments', 'reportCount'])
      );
      // Allow delete by owner, admin, or automatically if reported enough (client-side mod logic)
      allow delete: if isDocumentOwner(resource.data) || isAdmin() || (
        isAuthenticated() && resource.data.reportCount >= 5
      );
      
      // Post Comments
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        allow update: if isDocumentOwner(resource.data) || isAdmin() || (
          isAuthenticated() && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'reportCount'])
        );
        allow delete: if isDocumentOwner(resource.data) || isAdmin();
      }
    }
    
    // Meetups: Public Read, Owner Write + Public Join/Like/Report
    match /meetups/{meetupId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.hostId == request.auth.uid;
      allow update: if isDocumentOwner(resource.data) || isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'likes', 'likedBy', 'scrappedBy', 'comments', 
          'participantIds', 'pendingParticipantIds', 'reportCount'
        ])
      );
      allow delete: if isDocumentOwner(resource.data) || isAdmin() || (
        isAuthenticated() && resource.data.reportCount >= 5
      );
      
      // Meetup Comments
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        allow update: if isDocumentOwner(resource.data) || isAdmin() || (
          isAuthenticated() && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'reportCount'])
        );
        allow delete: if isDocumentOwner(resource.data) || isAdmin();
      }
    }
    
    // Jobs: Public Read, Owner Write + Public Like/Report
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update: if isDocumentOwner(resource.data) || isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'scrappedBy', 'reportCount'])
      );
      allow delete: if isDocumentOwner(resource.data) || isAdmin() || (
        isAuthenticated() && resource.data.reportCount >= 5
      );
    }
    
    // Marketplace: Public Read, Owner Write + Public Like/Report
    match /marketplace/{itemId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update: if isDocumentOwner(resource.data) || isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'scrappedBy', 'reportCount'])
      );
      allow delete: if isDocumentOwner(resource.data) || isAdmin() || (
        isAuthenticated() && resource.data.reportCount >= 5
      );
    }
    
    // Questions (QnA): Public Read, Owner Write + Public Like/Report
    match /questions/{questionId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update: if isDocumentOwner(resource.data) || isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'scrappedBy', 'comments', 'reportCount'])
      );
      allow delete: if isDocumentOwner(resource.data) || isAdmin() || (
        isAuthenticated() && resource.data.reportCount >= 5
      );
      
      // Answers
      match /answers/{answerId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        allow update: if isDocumentOwner(resource.data) || isAdmin() || (
          isAuthenticated() && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'reportCount'])
        );
        allow delete: if isDocumentOwner(resource.data) || isAdmin();
      }
    }

    // ==========================================================
    // USER DATA
    // ==========================================================
    
    match /users/{userId} {
      // Profiles are readable by authenticated users
      allow read: if isAuthenticated(); 
      
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
      
      // A user can fully update their own profile
      // OR another user can ONLY update specific social fields
      allow update: if isOwner(userId) || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'following', 'blockedBy'])
      ) || isAdmin();
      
      // Notifications
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if isAuthenticated(); 
        allow update, delete: if isOwner(userId);
      }
    }

    // ==========================================================
    // PRIVATE / CHAT
    // ==========================================================

    match /conversations/{conversationId} {
      // Only participants can read/write
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participantIds;
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participantIds || isAdmin());
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        // Only participants of the parent conversation can read/write messages
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if isDocumentOwner(resource.data) || isAdmin();
      }
    }

    // ==========================================================
    // DELETED / REPORTED CONTENT
    // ==========================================================
    
    match /deleted_users/{userId} {
      allow create, update: if isOwner(userId);
      allow read, delete: if isAdmin();
    }

    match /deleted_posts/{postId} {
      allow create, update: if isDocumentOwner(request.resource.data);
      allow read, delete: if isAdmin();
    }

    match /admin_restricted_posts/{postId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /user_restrictions/{restrictionId} {
      allow create: if isAuthenticated();
      allow read: if isDocumentOwner(resource.data) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /admin_reports/{reportId} {
      allow create: if isAuthenticated() && reportId == request.resource.data.postId + '_' + request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /admin_contact_inquiries/{inquiryId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // ==========================================================
    // DEFAULT CATCH-ALL
    // ==========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
